# FreeClaw Configuration
# Copy this file to .env and modify as needed

# Server Configuration
HOST=0.0.0.0
PORT=3002

# OpenCode CLI Path
# Windows example:
OPENCODE_PATH=D:\AI\bin\OpenCode\opencode-cli.exe
# Linux example:
# OPENCODE_PATH=~/.opencode/bin/opencode
# macOS example:
# OPENCODE_PATH=~/.opencode/bin/opencode

# Model Configuration
DEFAULT_MODEL=opencode/default

# Session Configuration
MAX_TOKENS=16000
SESSION_TIMEOUT=3600000

# Request Configuration
REQUEST_TIMEOUT=300000

# Tools Configuration
DEFAULT_TOOLS=read,write,bash,grep,glob,task
